// =============================================================================
// Proxmox Backup GUI — Fast pipeline
// Trigger : GitHub webhook (every push)
// Runtime : ~90s on Jenkins LXC, no VM needed
// Tests   : Unit tests (backend logic) + Playwright mock-server tests
// =============================================================================

pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'main',
               description: 'Branch to test (e.g. main, feature/backup-restore)')
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        ansiColor('xterm')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: "${params.BRANCH}"]],
                    userRemoteConfigs: scm.userRemoteConfigs
                )
                echo "Testing branch: ${params.BRANCH}"
            }
        }

        stage('Install deps') {
            steps {
                sh '''
                    python3 -m venv .venv
                    .venv/bin/pip install -q -r requirements.txt
                    .venv/bin/pip install -q pytest playwright
                    .venv/bin/playwright install chromium
                '''
            }
        }

        stage('Unit tests') {
            steps {
                sh '''
                    mkdir -p test-results
                    PYTHONUNBUFFERED=1 \
                    .venv/bin/pytest ci/tests/test_unit.py ci/tests/test_auth.py \
                        -v --tb=short --no-header --color=no \
                        --junit-xml=test-results/unit.xml
                '''
            }
        }

        stage('Mock tests') {
            steps {
                sh '''
                    PYTHONUNBUFFERED=1 \
                    .venv/bin/pytest ci/tests/test_frontend.py \
                        -v --tb=short --no-header --color=no \
                        --junit-xml=test-results/frontend-mock.xml
                '''
            }
        }
    }

    post {
        always {
            junit 'test-results/unit.xml, test-results/frontend-mock.xml'
            cleanWs()
        }
        success { echo "All tests passed — safe to merge" }
        failure { echo "Tests failed — check test-results/" }
    }
}
